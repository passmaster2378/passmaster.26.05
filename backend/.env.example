# 로컬 개발용 예시 — 이 파일을 복사해 `.env` 로 저장한 뒤 값을 채우세요.
# `.env` 는 git 에 올라가지 않습니다.

NODE_ENV=development
PORT=4000

# 32자 이상 (운영과 다른 값 권장)
JWT_SECRET=local-dev-change-me-to-at-least-32-chars-long

# Supabase / Postgres
SUPABASE_DB_URL=

# --- OAuth: 값은 각 개발자 콘솔에서만 발급 ---
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID (웹)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao Developers → 내 애플리케이션 → 앱 키 → REST API 키
# Client Secret 을 켠 앱이면 아래도 입력
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# 로컬에서 OAuth 콜백 URL 이 http://localhost:4000/api/auth/oauth/... 와 일치하도록
# 구글·카카오 콘솔 Redirect URI 에 동일 경로를 등록해야 합니다.
PUBLIC_API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5500
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

ROOT_ADMIN_BOOTSTRAP=false
ROOT_ADMIN_PASSWORD=
ROOT_ADMIN_NAME=PASSmaster
