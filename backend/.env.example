PORT=4000
JWT_SECRET=replace-with-long-random-secret
CORS_ORIGINS=http://localhost:5500,http://localhost:5173,https://your-frontend-domain.vercel.app
# OAuth redirect 검증 및 기본 로그인 URL (프론트 오리진, 경로 없이)
FRONTEND_URL=https://your-frontend-domain.vercel.app
# Google Cloud Console에 등록한 Web 클라이언트 (콜백: {PUBLIC_API_URL}/api/auth/oauth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Kakao Developers REST API 키 (콜백: {PUBLIC_API_URL}/api/auth/oauth/kakao/callback)
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
# Render 등 리버스 프록시 뒤에서 OAuth redirect_uri가 공개 URL과 일치하도록 설정
PUBLIC_API_URL=https://your-api.onrender.com

# Supabase (Postgres)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Prefer Supabase "Session pooler" URI in production (usually port 6543).
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-url-encoded-password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres




